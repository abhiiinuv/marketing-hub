// Deploy from creatorboard/ (canonical) or this copy — keep in sync with ../creatorboard/firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /creators/{creatorId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['claimedBy', 'fcmToken']);
    }

    match /weeklyStats/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /winners/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    function isMarketingAdmin() {
      return request.auth != null;
    }

    match /socialPosts/{docId} {
      allow read: if true;
      allow create, update, delete: if isMarketingAdmin();
    }

    match /videoReleases/{docId} {
      allow read: if true;
      allow create, update, delete: if isMarketingAdmin();
    }

    match /inHouseVideos/{docId} {
      allow read: if true;
      allow create, update, delete: if isMarketingAdmin();
    }

    match /collaborations/{docId} {
      allow read: if true;
      allow create, update, delete: if isMarketingAdmin();
    }

    match /collabBacklog/{docId} {
      allow read: if true;
      allow create, update, delete: if isMarketingAdmin();
    }

    match /campaigns/{docId} {
      allow read: if true;
      allow create, update, delete: if isMarketingAdmin();
    }

    match /trafficUploads/{docId} {
      allow read: if true;
      allow create, update, delete: if isMarketingAdmin();
    }
  }
}
